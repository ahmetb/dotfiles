{
  "cleanupPeriodDays": 99999,
  "model": "opus[1m]",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/abalkan/.claude/hooks/gsd-check-update.js\""
          }
        ]
      }
    ]
  },
  "_disabledHooks": {
    "_note": "Sound/notification hooks disabled. To re-enable, move these entries back into the \"hooks\" key above.",
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/notify.js\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/notify.js\"",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/go/bin/oh-my-posh claude --config ~/.claude.omp.yaml",
    "padding": 0
  },
  "enabledPlugins": {
    "ralph-loop@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "playground@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "sitehub@linkedin-plugins": true,
    "observe-agent@linkedin-plugins": true,
    "li-plugin-tool@linkedin-plugins": true,
    "linkedin-cli-tools@linkedin-plugins": true,
    "linkedin-dev-workflow@linkedin-plugins": true,
    "linkedin-framework@linkedin-plugins": true,
    "unit-tests@linkedin-plugins": true,
    "observe-metrics@linkedin-plugins": true
  },
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true,
  "editorMode": "vim",
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--extension"
      ]
    }
  }
}
