font-family = TX-02
font-thicken = true
font-size = 16
# adjust-cell-height = 0%

theme = Cobalt Next Minimal
auto-update-channel = stable

macos-titlebar-style = tabs
title = " "
# background-opacity = 1
unfocused-split-opacity = 0.7
unfocused-split-fill = "#333333"

window-width = 120
window-height = 30

scrollback-limit = 30000000
copy-on-select = clipboard

# Quick terminal
keybind = global:option+grave_accent=toggle_quick_terminal

keybind = shift+enter=text:\x1b\r

# disable programming ligatures
font-feature = -calt

# VT100 / retro CRT shader.
# Symlinked to ~/junk/ghostty-vt100-shader/vt100-crt.glsl — tune via the
# bundled playground.html and paste the CONFIG block back into the shader.
# custom-shader = ~/.config/ghostty/shaders/vt100-crt.glsl
# custom-shader = ~/.config/ghostty/shaders/in-game-crt.glsl
custom-shader-animation = true
